# =========================
# Copy2Image Workflow .env
# =========================

# ---- Text model (workflow analysis/outline/prompt steps) ----
COPY2IMAGE_WORKFLOW_TEXT_API_KEY=
COPY2IMAGE_WORKFLOW_TEXT_BASE_URL=https://api.openai.com/v1
COPY2IMAGE_WORKFLOW_TEXT_MODEL=gpt-4o-mini

# ---- Image model (rendering step) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional image API dialect:
# openai-native / ratio-metadata (depends on provider gateway support)
OPENAI_IMAGE_API_DIALECT=openai-native

# Optional text fallback keys (if you prefer generic names)
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

